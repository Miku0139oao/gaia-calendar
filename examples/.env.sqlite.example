APP_ADDR=:8080
APP_BASE_URL=http://localhost:8080
DATABASE_URL=sqlite://data/gaia-calendar.db

# Replace both secrets before using a public domain.
SESSION_SECRET=replace-with-a-random-session-secret
CREDENTIAL_ENCRYPTION_KEY=replace-with-a-random-encryption-secret

# Set false for local trials without email. Keep true for public deployments.
AUTH_EMAIL_VERIFICATION_REQUIRED=false

# Cloudflare Email Sending / Email Routing API.
# Registration and password reset require these values.
CLOUDFLARE_EMAIL_ACCOUNT_ID=
CLOUDFLARE_EMAIL_API_TOKEN=
CLOUDFLARE_EMAIL_FROM=no-reply@example.com

# Optional. Keep empty for a public or multi-company install.
GAIA_DEFAULT_COMPANY_CODE=
